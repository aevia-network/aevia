# /etc/aevia-node/env — relay node runtime config.
#
# Copy to /etc/aevia-node/env on each VPS. Restart the service after
# editing: systemctl restart aevia-node.

# BOOTSTRAP_PEERS is comma-separated list of /p2p-terminated multiaddrs.
# Relay 1 (cold start): leave BLANK. It's the seed itself.
# Relay 2 (joining): set to Relay 1's full multiaddr.
#
# Pattern: /ip4/<IP>/tcp/4001/p2p/<PEER_ID>
#
# Obtained after first boot from the first relay: grep the journal for
# "listening_libp2p addr=/ip4/..." and copy the full string.
AEVIA_BOOTSTRAP=

# Force-reachability pinned to public — VPS deploys bypass the AutoNAT
# probing phase since we know we have a public IP.
AEVIA_FORCE_REACHABILITY=public

# Listen addresses — 0.0.0.0 so libp2p binds all interfaces.
AEVIA_LISTEN=/ip4/0.0.0.0/tcp/4001
AEVIA_HTTP_ADDR=0.0.0.0:8080

# Persistent state directory — contains identity.key (Ed25519 private
# key derived PeerID) + BadgerDB for any future pinning.
AEVIA_DATA_DIR=/var/lib/aevia-node

# Mode: relay for VPS (Circuit Relay + DHT only), provider for
# content-serving nodes (WHIP ingest, HLS serving, pinning, optional TLS).
AEVIA_MODE=relay

# ---- HTTPS (provider mode only) ----
# When all three TLS fields are set, the provider-node embeds an
# ACME client (certmagic) that solves Let's Encrypt DNS-01 challenges
# via the Cloudflare API, then serves HTTPS on --tls-addr (default :443)
# alongside the HTTP listener on 8080. Cert + renewals land in
# ~/.aevia/provider-node/tls by default; override via AEVIA_TLS_CACHE_DIR.
# Leave these empty to keep HTTP-only.
AEVIA_TLS_DOMAIN=
AEVIA_TLS_EMAIL=
AEVIA_CF_API_TOKEN=
# Optional. Default ":443"; ":8443" if running unprivileged.
AEVIA_TLS_ADDR=
# Set to "true" during first-boot smoke tests so LE production rate
# limits don't bite; certs won't pass browsers but the pipeline is
# validated end-to-end. Flip back to empty for real issuance.
AEVIA_TLS_STAGING=
