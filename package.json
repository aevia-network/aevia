{
  "name": "aevia",
  "private": true,
  "version": "0.0.0",
  "description": "Aevia — sovereign video social protocol. Low-latency live, automatic VOD, viral clips, creator ownership, ethical moderation. Persistence does not imply distribution.",
  "homepage": "https://aevia.network",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aevia-network/aevia.git"
  },
  "license": "SEE LICENSE IN LICENSES.md",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --continue",
    "dev:web": "turbo run dev --filter='./apps/*'",
    "dev:services": "turbo run dev --filter='./services/*'",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:contracts": "pnpm --filter @aevia/contracts test",
    "proto:generate": "pnpm --filter @aevia/protocol generate",
    "proto:lint": "pnpm --filter @aevia/protocol lint",
    "proto:breaking": "pnpm --filter @aevia/protocol breaking",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "turbo run build --filter='./packages/*' && changeset publish",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.11",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "lefthook": "^1.10.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild", "lefthook", "sharp", "workerd"]
  }
}
