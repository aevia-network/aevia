BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# Prefer `cast wallet import` keystore over inline private key.
DEPLOYER_PRIVATE_KEY=

# Safe multisig addresses (set after Safe deployment in each network).
SAFE_ADDRESS_SEPOLIA=
SAFE_ADDRESS_MAINNET=

# USDC native on Base
USDC_ADDRESS_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# -----------------------------------------------------------------------
# Deployed Aevia contracts — canonical source of truth is
# packages/contracts/deployments/<chain>.json. These env vars exist so the
# Go coordinator binary, apps/video, apps/network, and shell scripts can
# reference addresses without parsing JSON. Keep in sync with deployments/.
# -----------------------------------------------------------------------

# ContentRegistry — on-chain anchor for signed manifest CIDs.
CONTENT_REGISTRY_ADDRESS_SEPOLIA=0x07ffbcB245bcD8aA08F8dA75B2AeDE750d5592F0
CONTENT_REGISTRY_ADDRESS_MAINNET=

# PersistencePool — holds cUSDC deposits + distributes via submitSettlement.
PERSISTENCE_POOL_ADDRESS_SEPOLIA=0x735C363a6df4651ABD8b1081F0b73fdAd98a4a93
PERSISTENCE_POOL_ADDRESS_MAINNET=

# Coordinator address submitting settlements. MVP equals deployer on Sepolia;
# mainnet will be a Safe multisig.
COORDINATOR_ADDRESS_SEPOLIA=0xe58ee3d7b6FF359dc5c8A67f3862362F9F4080ca
COORDINATOR_ADDRESS_MAINNET=
