BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=

# Prefer `cast wallet import` keystore over inline private key.
DEPLOYER_PRIVATE_KEY=

# USDC native on Base
USDC_ADDRESS_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
USDC_ADDRESS_MAINNET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# -----------------------------------------------------------------------
# Deployed Aevia contracts — canonical source of truth is
# packages/contracts/deployments/<chain>.json. These env vars exist so the
# Go coordinator binary, apps/video, apps/network, and shell scripts can
# reference addresses without parsing JSON. Keep in sync with deployments/.
# -----------------------------------------------------------------------

# ContentRegistry — on-chain anchor for signed manifest CIDs.
CONTENT_REGISTRY_ADDRESS_SEPOLIA=0x07ffbcB245bcD8aA08F8dA75B2AeDE750d5592F0
CONTENT_REGISTRY_ADDRESS_MAINNET=

# PersistencePool — holds cUSDC deposits + distributes via submitSettlement.
PERSISTENCE_POOL_ADDRESS_SEPOLIA=0x735C363a6df4651ABD8b1081F0b73fdAd98a4a93
PERSISTENCE_POOL_ADDRESS_MAINNET=

# RiskOracle — on-chain R(c) publication per RFC-6 §8.
RISK_ORACLE_ADDRESS_SEPOLIA=0xa5E6c7d8F5964f76D9f875819652a1ad2aE963AD
RISK_ORACLE_ADDRESS_MAINNET=

# BoostRouter — atomic 4-way boost splitter per RFC-8 §4.
BOOST_ROUTER_ADDRESS_SEPOLIA=0xf566C64a4052A21f95C267c58517E956fa2e8F82
BOOST_ROUTER_ADDRESS_MAINNET=

# Coordinator address submitting settlements. MVP equals deployer on Sepolia;
# mainnet will be a Safe multisig.
COORDINATOR_ADDRESS_SEPOLIA=0xe58ee3d7b6FF359dc5c8A67f3862362F9F4080ca
COORDINATOR_ADDRESS_MAINNET=

# -----------------------------------------------------------------------
# Gnosis Safe multisigs — 2-of-2 (deployer + MM Account 1) on Sepolia.
# ⚠️ Signer 2 MUST rotate to real spouse wallet before mainnet value via
# Safe swapOwner tx (no redeploy needed). See TODO §14.2.
# Canonical source: packages/contracts/deployments/base-sepolia.json
# -----------------------------------------------------------------------

# LLCTreasury — receives llcBps of boosts + relayer/aggregator fees.
LLC_TREASURY_SAFE_SEPOLIA=0xA98A148bD5493ee6F1AF2344C384E77fAEF2a2Ef
LLC_TREASURY_SAFE_MAINNET=

# CouncilFund — receives councilBps (1% of boosts) for Council operations.
COUNCIL_FUND_SAFE_SEPOLIA=0x7F99fFA84589C40a0FFc15A9451205dbF4a93EB1
COUNCIL_FUND_SAFE_MAINNET=

# Council governance — sole authority for setSplit / setCouncil on
# BoostRouter and contestScore / resolveContest / rotateScoringServiceKey
# on RiskOracle.
COUNCIL_SAFE_SEPOLIA=0x4934f9BA21F7Af797d4b89ead35Cf28Cdc1E72Ae
COUNCIL_SAFE_MAINNET=

# -----------------------------------------------------------------------
# RiskOracle Scoring service signer — publishes R(c) on-chain per RFC-6
# §8.4. Bootstrap = deployer EOA under LLC custody. Rotate via Council
# (`rotateScoringServiceKey`) when operational. NOT rotatable by
# Operator unilaterally.
# -----------------------------------------------------------------------
SCORING_SERVICE_ADDRESS_SEPOLIA=0xe58ee3d7b6FF359dc5c8A67f3862362F9F4080ca
SCORING_SERVICE_ADDRESS_MAINNET=
