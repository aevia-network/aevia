      "types": "./src/server.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@privy-io/react-auth": "catalog:",
    "@privy-io/server-auth": "catalog:",
    "viem": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:"
  }
