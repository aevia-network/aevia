{
  "name": "@aevia/auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "Apache-2.0",
  "description": "Privy-wrapped auth primitives for Aevia: DID resolution, session, EIP-712 manifest signing.",
  "main": "./src/index.ts",
