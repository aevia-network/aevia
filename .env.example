# Copy to .env.local for local dev; never commit .env.local.

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ---- Cloudflare ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Cloudflare Stream
STREAM_API_TOKEN=
STREAM_WEBHOOK_SECRET=
NEXT_PUBLIC_STREAM_CUSTOMER_CODE=

# ---- Aevia Provider Node (zero-Cloudflare WHIP/WHEP) ----
# When set, /api/lives + /live/[id] + the browser WHIP publisher talk to
# our provider-node mesh (services/provider-node, M8) instead of
# Cloudflare Stream. Leave empty to keep Cloudflare Stream as backend.
# Dev default: http://127.0.0.1:8080 (run deploy/e2e/run-m8.sh start-mac).
PROVIDER_BASE_URL=
NEXT_PUBLIC_PROVIDER_BASE_URL=

# ---- Privy (auth) ----
# https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# ---- Base L2 ----
BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ---- Deployer (contracts) ----
# Prefer `cast wallet import` + keystore over inline private key.
DEPLOYER_PRIVATE_KEY=
BASESCAN_API_KEY=

# ---- Gas-sponsored registration relayer ----
# Edge runtime signs/submits `registerContent` on behalf of creators. The
# user still signs the EIP-712 typed data; this key only pays gas. Generate
# locally with `viem/accounts.generatePrivateKey()`. Keep separate from the
# deployer key.
RELAYER_PRIVATE_KEY=

# ---- Session / signing ----
# openssl rand -hex 32
SESSION_SIGNING_KEY=

# ---- libp2p (Sprint 3+) ----
AEVIA_BOOTSTRAP_PEERS=

# ---- Turbo remote cache (optional) ----
TURBO_TOKEN=
TURBO_TEAM=
