# Copy to .env.local for local dev; never commit .env.local.

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ENV=development

# ---- Cloudflare ----
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=

# Cloudflare Stream
STREAM_API_TOKEN=
STREAM_WEBHOOK_SECRET=
NEXT_PUBLIC_STREAM_CUSTOMER_CODE=

# ---- Aevia Mesh (opt-in per live, Cloudflare stays default) ----
# Creators on /live/new see a radio: "via cloudflare (padrão)" vs
# "via rede aevia — experimental". When they pick the mesh option, the
# browser posts WHIP straight to NEXT_PUBLIC_AEVIA_MESH_URL (bypassing
# Cloudflare Stream) and the viewer plays HLS from the same URL.
# Leave empty to disable the mesh option entirely (radio hides).
NEXT_PUBLIC_AEVIA_MESH_URL=

# Cloudflare DNS API token used by provider-node (Go binary) to solve
# Let's Encrypt DNS-01 challenges and auto-renew TLS certs for its
# public HTTPS endpoint. Create at
# https://dash.cloudflare.com/profile/api-tokens with exactly
# Zone > DNS > Edit on the zone the node serves on. Keep out of git.
AEVIA_CF_API_TOKEN=

# ---- Privy (auth) ----
# https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=

# Dev-only bypass that skips Privy entirely — for e2e testing the video
# pipeline without walletconnect SSR 500 blocking page loads. When true:
# (1) middleware skips cookie gate, (2) readAeviaSession returns a fixed
# mock session, (3) providers.tsx skips AeviaPrivyProvider so
# @walletconnect/* never enters the SSR chunk.
# MUST be empty/false in prod deploys.
AEVIA_DEV_BYPASS_AUTH=
NEXT_PUBLIC_AEVIA_DEV_BYPASS_AUTH=
PRIVY_APP_SECRET=

# ---- Base L2 ----
BASE_CHAIN_ID=84532
NEXT_PUBLIC_BASE_CHAIN_ID=84532
BASE_RPC_URL=https://sepolia.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://mainnet.base.org

# ---- Deployer (contracts) ----
# Prefer `cast wallet import` + keystore over inline private key.
DEPLOYER_PRIVATE_KEY=
BASESCAN_API_KEY=

# ---- Gas-sponsored registration relayer ----
# Edge runtime signs/submits `registerContent` on behalf of creators. The
# user still signs the EIP-712 typed data; this key only pays gas. Generate
# locally with `viem/accounts.generatePrivateKey()`. Keep separate from the
# deployer key.
RELAYER_PRIVATE_KEY=

# ---- Session / signing ----
# openssl rand -hex 32
SESSION_SIGNING_KEY=

# ---- libp2p (Sprint 3+) ----
AEVIA_BOOTSTRAP_PEERS=

# ---- Turbo remote cache (optional) ----
TURBO_TOKEN=
TURBO_TEAM=
